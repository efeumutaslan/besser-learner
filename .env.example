# Database - SQLite (dev) or PostgreSQL (production)
DATABASE_URL="file:./dev.db"

# JWT Secret - ZORUNLU. Minimum 32 karakter, rastgele bir string kullanin.
# Olusturmak icin: openssl rand -base64 48
JWT_SECRET="your-secret-key-here-min-32-chars"

# Uygulama URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upload dizini (local fallback)
UPLOAD_DIR="./uploads"

# GitHub Storage - Medya dosyalari icin (resim/ses)
# Bos birakirsaniz dosyalar locale kaydedilir.
# Public bir repo olusturun, sonra Fine-grained Personal Access Token alin:
#   Settings > Developer settings > Personal access tokens > Fine-grained tokens
#   Repository access: Only select repositories > reponuzu secin
#   Permissions: Contents (Read and Write)
GITHUB_STORAGE_TOKEN=""
GITHUB_STORAGE_OWNER=""
GITHUB_STORAGE_REPO=""

# Pixabay API - Otomatik kart resmi icin (opsiyonel)
# Ucretsiz kayit: https://pixabay.com/api/docs/
# Bos birakirsaniz kartlara resim eklenmez.
PIXABAY_API_KEY=""
